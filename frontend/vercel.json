{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "VITE_API_URL@production": "https://api.example.com",
    "VITE_APP_NAME@production": "CAAC",
    "VITE_ENVIRONMENT@production": "production",
    "VITE_LOG_LEVEL@production": "error",
    "VITE_FEATURE_FLAG_DEBUG@production": "false"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
