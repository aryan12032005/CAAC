{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "VITE_API_URL": "@vite_api_url",
    "VITE_APP_NAME": "CAAC",
    "VITE_ENVIRONMENT": "production",
    "VITE_LOG_LEVEL": "error",
    "VITE_FEATURE_FLAG_DEBUG": "false"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
